# kopia-browser configuration. Copy to .env for local dev (.env is gitignored).
# Never commit real secret values.

# S3 / Garage connection
S3_ENDPOINT=        # host:port, e.g. tailscale-garage-s3:3900 (HTTP, no TLS)
S3_REGION=garage    # default: garage
S3_BUCKET=velero-backup  # default: velero-backup
S3_ACCESS_KEY=      # required
S3_SECRET_KEY=      # required

# kopia repository
KOPIA_REPO_PASSWORD=  # required; shared Velero-set repo password
KOPIA_PREFIX=kopia/   # default: kopia/ (repos live at kopia/<namespace>/)
KOPIA_CACHE_DIR=.kopia-cache  # default: .kopia-cache (writable; per-ns repo config + cache)
KOPIA_CONTENT_CACHE_MB=5120  # default: 5120 (5 GB); set 0 to disable disk cache

# HTTP server
LISTEN_ADDR=:8080   # default: :8080

# Dashboard statistics cache
STATS_REFRESH_INTERVAL=60m  # default: 60m; how often background stats refresh (Go duration)

# Logging
LOG_LEVEL=              # default: info; one of debug|info|warn|error
